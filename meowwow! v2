def V_eff_thermal(H: float, p: Dict[str, float], T: float) -> float:
    """Finite-temperature effective potential (1-loop thermal)."""
    V0 = V_eff(H, p)
    
    # Thermal masses (schematic)
    c_s = 0.25 * p["lambda_H"] + 0.25 * p["y"]**2 + 0.1 * p["g"]**2
    mH2 = p["m2"] + 3 * p["lambda_H"] * H**2 + c_s * T**2
    mG2 = p["m2"] + p["lambda_H"] * H**2 + c_s * T**2
    mpsi2 = (p["y"] * H)**2
    mA2 = (p["g"] * H)**2 + 0.1 * T**2
    
    def J_b(x2):
        if x2 < 1e-6:
            return -math.pi**4/45.0 + math.pi**2/12.0 * x2 - math.pi/6.0 * x2**1.5
        return -math.sqrt(2*math.pi) * x2**1.5 * math.exp(-math.sqrt(x2))
    
    def J_f(x2):
        if x2 < 1e-6:
            return -7.0*math.pi**4/360.0 + math.pi**2/24.0 * x2
        return -math.sqrt(2*math.pi) * x2**1.5 * math.exp(-math.sqrt(x2))
    
    V_thermal = 0.0
    V_thermal += T**4 * J_b(max(0.0, mH2 / T**2))
    V_thermal += T**4 * J_b(max(0.0, mG2 / T**2))
    V_thermal += 3 * T**4 * J_b(max(0.0, mA2 / T**2))
    V_thermal += -4 * T**4 * J_f(max(0.0, mpsi2 / T**2))
    
    return V0 + V_thermal

def find_critical_temperature(params: Dict[str, float], H_scan: Tuple[float, float] = (0.0, 10.0),
                               T_max: float = 500.0) -> Optional[float]:
    """Find critical temperature where minima are degenerate."""
    def Vdiff(T):
        Hs = np.linspace(H_scan[0], H_scan[1], 201)
        Vs = [V_eff_thermal(H, params, T) for H in Hs]
        idx = int(np.argmin(Vs))
        H_min = Hs[idx]
        V_min = Vs[idx]
        V0 = V_eff_thermal(0.0, params, T)
        return V_min - V0
    
    Ts = np.linspace(0.0, T_max, 101)
    vals = [Vdiff(T) for T in Ts]
    
    for i in range(len(Ts) - 1):
        if vals[i] * vals[i+1] <= 0:
            try:
                Tc = brentq(Vdiff, Ts[i], Ts[i+1], xtol=1e-3)
                return Tc
            except Exception:
                continue
    return None

