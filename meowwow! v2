    beta_yu = y_u * (
        a_u * y_u**2
        - c_u1 * g1**2
        - c_u2 * g2**2
        - c_u3 * g3**2
    ) / (16*math.pi**2)

    # For y_d, y_e we keep schematic small running
    beta_yd = y_d * (3*y_d**2 - 3*g2**2 - 3*g3**2) / (16*math.pi**2)
    beta_ye = y_e * (3*y_e**2 - 3*g2**2 - 3*g1**2) / (16*math.pi**2)

    # Higgs quartic beta (SM-like schematic)
    beta_lam = (
        24*lam**2
        - 6*y_u**4
        - 6*y_d**4
        - 2*y_e**4
        + (3/8)*(2*g2**4 + (g2**2 + g1**2)**2)
        + lam*(12*y_u**2 + 12*y_d**2 + 4*y_e**2 - 9*g2**2 - 3*g1**2)
    ) / (16*math.pi**2)

    return {
        "g1": beta_g1,
        "g2": beta_g2,
        "g3": beta_g3,
        "y_u": beta_yu,
        "y_d": beta_yd,
        "y_e": beta_ye,
        "lambda_H": beta_lam
    }

