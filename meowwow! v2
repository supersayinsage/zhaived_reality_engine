#!/usr/bin/env python3
"""
Adaptive parameter-space scan for the VALARI / MeowWow! physics engine.
- Uses the V_eff, dV, d2V functions from your monolith (finite-difference derivatives).
- Scans (lambda_H, y, g, m2) with adaptive refinement near phase boundaries and mu_inst gradients.
- Integrates one-loop RG from mu0=1 to mu_max=1e16 using a simple ODE integrator.
- Produces JSON summary of benchmarks, sample RG traces, and PNG plots (phase slices, mu_inst contours, histograms).
- Drop this file into the same folder as your monolith code and run: python3 adaptive_scan.py
"""
import os
import json
import math
import numpy as np
import multiprocessing as mp
import matplotlib.pyplot as plt
from functools import partial
from scipy.integrate import solve_ivp

# ---------------------------
# User-tunable scan settings
# ---------------------------
SCAN_CONFIG = {
    "lambda_H": {"min": 0.01, "max": 0.5, "points": 25},  # coarse default, adaptive will refine
    "y":        {"min": 0.1,  "max": 1.0, "points": 25},
    "g":        {"min": 0.05, "max": 0.6, "points": 20},
    "m2":       {"min": -2.0, "max": -0.1,"points": 20},
    "mu0": 1.0,
    "mu_max": 1e16,
    "rg_steps": 300,
    "adaptive_threshold_phase_change": 0.5,   # fraction of neighbors with different phase to trigger refine
    "adaptive_threshold_mu_grad": 0.2,        # relative gradient threshold to trigger refine
    "max_refinements": 2,
    "out_dir": "scan_output",
    "parallel_workers": max(1, mp.cpu_count() - 1)
}

os.makedirs(SCAN_CONFIG["out_dir"], exist_ok=True)

# ---------------------------
# Import or define physics functions
# ---------------------------
# The following functions must match the monolith's definitions.
# If you have them in a module, import them instead of redefining.
# For safety, these are minimal wrappers that mirror the monolith finite-difference approach.

def masses_sq(H, p):
    return {
        "M_H2": p["m2"] + 3*p["lambda_H"]*H**2,
        "M_G2": p["m2"] + p["lambda_H"]*H**2,
        "M_psi2": (p["y"]*H)**2,
        "M_A2": (p["g"]*H)**2,
    }

def loop_term(M2, n, mu, c=1.5):
    if M2 <= 0:
        M2 = abs(M2) + 1e-12
    return n * (M2**2) * (math.log(M2 / (mu**2)) - c) / (64 * math.pi**2)

def V_one_loop(H, p):
    ms = masses_sq(H, p)
    mu = p["mu"]
    Vb = (
        loop_term(ms["M_H2"], 1, mu) +
        loop_term(ms["M_G2"], 1, mu) +
        loop_term(ms["M_A2"], 3, mu)
    )
    Vf = -loop_term(ms["M_psi2"], 4, mu)
    return Vb + Vf

def V_tree(H, p):
    return 0.5 * p["m2"] * H**2 + 0.25 * p["lambda_H"] * H**4

def V_eff(H, p):
    return V_tree(H, p) + V_one_loop(H, p)

def dV(H, p, eps=1e-5):
    return (V_eff(H+eps, p) - V_eff(H-eps, p)) / (2*eps)

def d2V(H, p, eps=1e-4):
    return (V_eff(H+eps, p) - 2*V_eff(H, p) + V_eff(H-eps, p)) / (eps**2)

# ---------------------------
# One-loop beta functions (schematic)
# Replace coefficients with exact group-theory factors if available.
# ---------------------------
def beta_one_loop(g, y, lam):
    """
    Returns (beta_g, beta_y, beta_lambda) at one-loop.
    Coefficients are schematic and chosen to reflect typical structure.
    Adjust to match your exact model normalization.
    """
    # gauge beta: bg = b_g * g^3
    b_g = -7.0  # placeholder (negative for asymptotic freedom; change to your model)
    beta_g = b_g * g**3 / (16 * math.pi**2)

    # yukawa beta: by = y*(a*y^2 - c*g^2)
    a_y = 3.0
    c_y = 3.0
    beta_y = y * (a_y * y**2 - c_y * g**2) / (16 * math.pi**2)

    # quartic beta: schematic
    beta_lam = (3*lam**2 + 4*lam*y**2 - 8*y**4 - 6*lam*g**2 + 3*g**4) / (16 * math.pi**2)

    return beta_g, beta_y, beta_lam

# ---------------------------
# RG integration
# ---------------------------
def integrate_rg(mu0, mu_max, params, steps=300):
    """
    Integrate RG using simple explicit RK via solve_ivp on d/d(ln mu).
    Returns trace dict and mu_instability (first mu where lambda <= 0) or None.
    """
    def rhs(lnmu, yvec):
        g, y, lam = yvec
        bg, by, bl = beta_one_loop(g, y, lam)
        # d/d ln mu = beta
        return [bg, by, bl]

    y0 = [params["g"], params["y"], params["lambda_H"]]
    ln_mu0 = math.log(mu0)
    ln_mu_max = math.log(mu_max)
    t_eval = np.linspace(ln_mu0, ln_mu_max, steps)

    sol = solve_ivp(rhs, (ln_mu0, ln_mu_max), y0, t_eval=t_eval, method="RK45", rtol=1e-6, atol=1e-9)
    mus = np.exp(sol.t)
    gs, ys, lams = sol.y

    mu_inst = None
    for mu, lam in zip(mus, lams):
        if lam <= 0:
            mu_inst = mu
            break

    trace = {"mu": mus.tolist(), "g": gs.tolist(), "y": ys.tolist(), "lambda": lams.tolist()}
    return trace, mu_inst

# ---------------------------
# Discovery utilities
# ---------------------------
def find_minimum_scan(params, H_max=20.0, H_step=0.05):
    H_values = np.arange(0.0, H_max + H_step, H_step)
    V_values = [V_eff(float(H), params) for H in H_values]
    idx = int(np.argmin(V_values))
    H_min = float(H_values[idx])
    V_min = float(V_values[idx])
    try:
        m_H = math.sqrt(abs(d2V(H_min, params)))
    except Exception:
        m_H = None
    m_psi = params["y"] * H_min
    m_A = params["g"] * H_min
    phase = "BROKEN" if H_min > 1e-6 else "SYMMETRIC"
    return {"H_min": H_min, "V_min": V_min, "Higgs_mass": m_H, "Fermion_mass": m_psi, "Gauge_mass": m_A, "phase": phase}

# ---------------------------
# Single-point evaluation (worker)
# ---------------------------
def evaluate_point(point):
    """
    point: dict with keys lambda_H, y, g, m2
    returns: dict with params, discovery, rg summary, mu_inst
    """
    p = {
        "lambda_H": float(point["lambda_H"]),
        "y": float(point["y"]),
        "g": float(point["g"]),
        "m2": float(point["m2"]),
        "mu": float(SCAN_CONFIG["mu0"])
    }
    # Necessity quick check (VEV estimate)
    try:
        v_guess = math.sqrt(abs(p["m2"]) / p["lambda_H"])
        num = dV(v_guess, p)
        den = d2V(v_guess, p)
        v_eff = v_guess - num / den
    except Exception:
        v_eff = None

    discovery = find_minimum_scan(p)
    rg_trace, mu_inst = integrate_rg(SCAN_CONFIG["mu0"], SCAN_CONFIG["mu_max"], p, steps=SCAN_CONFIG["rg_steps"])

    result = {
        "params": p,
        "v_eff_estimate": v_eff,
        "discovery": discovery,
        "rg_mu_instability": mu_inst,
        "rg_trace_sample": {
            "mu": rg_trace["mu"][:: max(1, len(rg_trace["mu"])//50)],
            "lambda": rg_trace["lambda"][:: max(1, len(rg_trace["lambda"])//50)],
            "y": rg_trace["y"][:: max(1, len(rg_trace["y"])//50)],
            "g": rg_trace["g"][:: max(1, len(rg_trace["g"])//50)]
        }
    }
    return result

# ---------------------------
# Grid generation and adaptive refinement
# ---------------------------
def generate_grid(config):
    lam_vals = np.linspace(config["lambda_H"]["min"], config["lambda_H"]["max"], config["lambda_H"]["points"])
    y_vals   = np.linspace(config["y"]["min"], config["y"]["max"], config["y"]["points"])
    g_vals   = np.linspace(config["g"]["min"], config["g"]["max"], config["g"]["points"])
    m2_vals  = np.linspace(config["m2"]["min"], config["m2"]["max"], config["m2"]["points"])
    grid = []
    for lam in lam_vals:
        for y in y_vals:
            for g in g_vals:
                for m2 in m2_vals:
                    grid.append({"lambda_H": lam, "y": y, "g": g, "m2": m2})
    return grid

def coarse_then_refine(config):
    """
    Strategy:
    - Evaluate a coarse grid (reduced points).
    - Identify cells where phase changes among neighbors or mu_inst gradient large.
    - Refine those regions by subdividing parameter ranges locally.
    - Repeat up to max_refinements.
    """
    # Start with coarse grid (reduce points to keep runtime reasonable)
    coarse_cfg = config.copy()
    coarse_cfg["lambda_H"] = {"min": config["lambda_H"]["min"], "max": config["lambda_H"]["max"], "points": max(6, config["lambda_H"]["points"]//4)}
    coarse_cfg["y"] = {"min": config["y"]["min"], "max": config["y"]["max"], "points": max(6, config["y"]["points"]//4)}
    coarse_cfg["g"] = {"min": config["g"]["min"], "max": config["g"]["max"], "points": max(6, config["g"]["points"]//4)}
    coarse_cfg["m2"] = {"min": config["m2"]["min"], "max": config["m2"]["max"], "points": max(6, config["m2"]["points"]//4)}

    # Evaluate coarse grid
    coarse_grid = generate_grid(coarse_cfg)
    print(f"[scan] Coarse grid size: {len(coarse_grid)}")
    with mp.Pool(processes=SCAN_CONFIG["parallel_workers"]) as pool:
        coarse_results = pool.map(evaluate_point, coarse_grid)

    # Build a simple lookup by quantized indices to detect neighbors
    # For simplicity, map each coarse point to a tuple of indices
    lam_vals = np.linspace(coarse_cfg["lambda_H"]["min"], coarse_cfg["lambda_H"]["max"], coarse_cfg["lambda_H"]["points"])
    y_vals   = np.linspace(coarse_cfg["y"]["min"], coarse_cfg["y"]["max"], coarse_cfg["y"]["points"])
    g_vals   = np.linspace(coarse_cfg["g"]["min"], coarse_cfg["g"]["max"], coarse_cfg["g"]["points"])
    m2_vals  = np.linspace(coarse_cfg["m2"]["min"], coarse_cfg["m2"]["max"], coarse_cfg["m2"]["points"])

    index_map = {}
    for res in coarse_results:
        p = res["params"]
        i = int(np.argmin(np.abs(lam_vals - p["lambda_H"])))
        j = int(np.argmin(np.abs(y_vals - p["y"])))
        k = int(np.argmin(np.abs(g_vals - p["g"])))
        l = int(np.argmin(np.abs(m2_vals - p["m2"])))
        index_map[(i,j,k,l)] = res

    # Identify cells to refine
    refine_regions = []
    for key, res in index_map.items():
        i,j,k,l = key
        phase = res["discovery"]["phase"]
        # check neighbors in +/-1 in each axis
        neighbor_phases = []
        neighbor_muinst = []
        for di in (-1,0,1):
            for dj in (-1,0,1):
                for dk in (-1,0,1):
                    for dl in (-1,0,1):
                        nk = (i+di, j+dj, k+dk, l+dl)
                        if nk in index_map and nk != key:
                            neighbor_phases.append(index_map[nk]["discovery"]["phase"])
                            muinst = index_map[nk]["rg_mu_instability"]
                            if muinst is not None:
                                neighbor_muinst.append(muinst)
        # phase change fraction
        if neighbor_phases:
            diff_frac = sum(1 for ph in neighbor_phases if ph != phase) / len(neighbor_phases)
        else:
            diff_frac = 0.0
        # mu_inst gradient measure
        mu_here = res["rg_mu_instability"] or config["mu_max"]
        if neighbor_muinst:
            avg_neighbor_mu = sum(neighbor_muinst) / len(neighbor_muinst)
            rel_grad = abs(mu_here - avg_neighbor_mu) / max(1.0, avg_neighbor_mu)
        else:
            rel_grad = 0.0

        if diff_frac >= config["adaptive_threshold_phase_change"] or rel_grad >= config["adaptive_threshold_mu_grad"]:
            # record the parameter box to refine
            lam_c = lam_vals[i]
            y_c = y_vals[j]
            g_c = g_vals[k]
            m2_c = m2_vals[l]
            refine_regions.append((lam_c, y_c, g_c, m2_c))

    print(f"[scan] Regions flagged for refinement: {len(refine_regions)}")

    # Build refined points around flagged centers
    refined_points = []
    delta_lam = (coarse_cfg["lambda_H"]["max"] - coarse_cfg["lambda_H"]["min"]) / (coarse_cfg["lambda_H"]["points"] - 1)
    delta_y   = (coarse_cfg["y"]["max"] - coarse_cfg["y"]["min"]) / (coarse_cfg["y"]["points"] - 1)
    delta_g   = (coarse_cfg["g"]["max"] - coarse_cfg["g"]["min"]) / (coarse_cfg["g"]["points"] - 1)
    delta_m2  = (coarse_cfg["m2"]["max"] - coarse_cfg["m2"]["min"]) / (coarse_cfg["m2"]["points"] - 1)

    for center in refine_regions:
        lam_c, y_c, g_c, m2_c = center
        lam_range = np.linspace(max(SCAN_CONFIG["lambda_H"]["min"], lam_c - delta_lam), min(SCAN_CONFIG["lambda_H"]["max"], lam_c + delta_lam), 5)
        y_range   = np.linspace(max(SCAN_CONFIG["y"]["min"], y_c - delta_y), min(SCAN_CONFIG["y"]["max"], y_c + delta_y), 5)
        g_range   = np.linspace(max(SCAN_CONFIG["g"]["min"], g_c - delta_g), min(SCAN_CONFIG["g"]["max"], g_c + delta_g), 5)
        m2_range  = np.linspace(max(SCAN_CONFIG["m2"]["min"], m2_c - delta_m2), min(SCAN_CONFIG["m2"]["max"], m2_c + delta_m2), 5)
        for lam in lam_range:
            for y in y_range:
                for g in g_range:
                    for m2 in m2_range:
                        refined_points.append({"lambda_H": lam, "y": y, "g": g, "m2": m2})

    # Remove duplicates by hashing param tuple
    seen = set()
    unique_refined = []
    for p in refined_points:
        key = (round(p["lambda_H"],8), round(p["y"],8), round(p["g"],8), round(p["m2"],8))
        if key not in seen:
            seen.add(key)
            unique_refined.append(p)

    print(f"[scan] Refined points to evaluate: {len(unique_refined)}")

    # Evaluate refined points in parallel
    with mp.Pool(processes=SCAN_CONFIG["parallel_workers"]) as pool:
        refined_results = pool.map(evaluate_point, unique_refined)

    # Combine coarse and refined results
    combined = coarse_results + refined_results
    return combined

# ---------------------------
# Postprocessing and plotting
# ---------------------------
def postprocess_and_save(results, out_dir):
    # Save raw JSON
    out_json = os.path.join(out_dir, "scan_results.json")
    with open(out_json, "w") as f:
        json.dump(results, f, indent=2)

    # Extract benchmark categories
    stable = []
    metastable = []
    unstable = []
    for r in results:
        mu_inst = r["rg_mu_instability"]
        phase = r["discovery"]["phase"]
        if phase == "BROKEN" and (mu_inst is None):
            stable.append(r)
        elif phase == "BROKEN" and (mu_inst is not None):
            metastable.append(r)
        else:
            unstable.append(r)

    # Save small JSONs for benchmarks
    def save_subset(name, arr, limit=10):
        path = os.path.join(out_dir, f"{name}_benchmarks.json")
        with open(path, "w") as f:
            json.dump(arr[:limit], f, indent=2)

    save_subset("stable", stable)
    save_subset("metastable", metastable)
    save_subset("unstable", unstable)

    # Histograms of masses
    H_masses = [r["discovery"]["Higgs_mass"] for r in results if r["discovery"]["Higgs_mass"] is not None]
    psi_masses = [r["discovery"]["Fermion_mass"] for r in results]
    A_masses = [r["discovery"]["Gauge_mass"] for r in results]

    plt.figure(figsize=(8,6))
    plt.hist([m for m in H_masses if m is not None], bins=40, color="C0", alpha=0.8)
    plt.title("Higgs mass distribution (scan)")
    plt.xlabel("m_H (model units)")
    plt.ylabel("counts")
    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, "hist_higgs_mass.png"))
    plt.close()

    plt.figure(figsize=(8,6))
    plt.hist(psi_masses, bins=40, color="C1", alpha=0.8)
    plt.title("Fermion mass distribution (scan)")
    plt.xlabel("m_psi (model units)")
    plt.ylabel("counts")
    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, "hist_fermion_mass.png"))
    plt.close()

    plt.figure(figsize=(8,6))
    plt.hist(A_masses, bins=40, color="C2", alpha=0.8)
    plt.title("Gauge mass distribution (scan)")
    plt.xlabel("m_A (model units)")
    plt.ylabel("counts")
    plt.tight_layout()
    plt.savefig(os.path.join(out_dir, "hist_gauge_mass.png"))
    plt.close()

    # Simple 2D phase slice: fix m2 at baseline and g at baseline, vary lambda_H vs y
    baseline_m2 = -1.0
    baseline_g = 0.3
    slice_points = [r for r in results if abs(r["params"]["m2"] - baseline_m2) < 1e-6 and abs(r["params"]["g"] - baseline_g) < 1e-6]
    if slice_points:
        lam_vals = sorted(list(set([round(r["params"]["lambda_H"],6) for r in slice_points])))
        y_vals = sorted(list(set([round(r["params"]["y"],6) for r in slice_points])))
        lam_vals_sorted = sorted(lam_vals)
        y_vals_sorted = sorted(y_vals)
        grid_phase = np.zeros((len(y_vals_sorted), len(lam_vals_sorted)))
        grid_muinst = np.full((len(y_vals_sorted), len(lam_vals_sorted)), np.nan)
        lam_to_idx = {v:i for i,v in enumerate(lam_vals_sorted)}
        y_to_idx = {v:i for i,v in enumerate(y_vals_sorted)}
        for r in slice_points:
            i = y_to_idx[round(r["params"]["y"],6)]
            j = lam_to_idx[round(r["params"]["lambda_H"],6)]
            grid_phase[i,j] = 1.0 if r["discovery"]["phase"] == "BROKEN" else 0.0
            grid_muinst[i,j] = r["rg_mu_instability"] or np.nan

        plt.figure(figsize=(8,6))
        plt.imshow(grid_phase, origin="lower", aspect="auto", extent=[min(lam_vals_sorted), max(lam_vals_sorted), min(y_vals_sorted), max(y_vals_sorted)], cmap="coolwarm")
        plt.colorbar(label="phase (1=BROKEN, 0=SYMMETRIC)")
        plt.xlabel("lambda_H")
        plt.ylabel("y")
        plt.title(f"Phase slice at m2={baseline_m2}, g={baseline_g}")
        plt.tight_layout()
        plt.savefig(os.path.join(out_dir, "phase_slice_lambda_vs_y.png"))
        plt.close()

        plt.figure(figsize=(8,6))
        plt.contourf(lam_vals_sorted, y_vals_sorted, np.nan_to_num(grid_muinst, nan=0.0), levels=20, cmap="viridis")
        plt.colorbar(label="mu_instability (0 => no crossing in range)")
        plt.xlabel("lambda_H")
        plt.ylabel("y")
        plt.title(f"mu_instability contour at m2={baseline_m2}, g={baseline_g}")
        plt.tight_layout()
        plt.savefig(os.path.join(out_dir, "muinst_contour_lambda_vs_y.png"))
        plt.close()

    print(f"[scan] Results saved to {out_dir}")

# ---------------------------
# Main driver
# ---------------------------
def main():
    print("[scan] Starting adaptive parameter-space scan")
    combined_results = coarse_then_refine(SCAN_CONFIG)
    # Convert results to JSON-serializable form
    serializable = []
    for r in combined_results:
        serializable.append({
            "params": r["params"],
            "v_eff_estimate": r["v_eff_estimate"],
            "discovery": r["discovery"],
            "rg_mu_instability": r["rg_mu_instability"],
            "rg_trace_sample": r["rg_trace_sample"]
        })
    postprocess_and_save(serializable, SCAN_CONFIG["out_dir"])
    print("[scan] Done.")

if __name__ == "__main__":
    main()
