    def masses_sq(H, p):
        return {
            "M_H2": p["m2"] + 3*p["lambda_H"]*H**2,
            "M_G2": p["m2"] + p["lambda_H"]*H**2,
            "M_psi2": (p["y"]*H)**2,
            "M_A2": (p["g"]*H)**2,
        }
    def loop_term(M2, n, mu, c=1.5):
        if M2 <= 0:
            M2 = abs(M2) + 1e-12
        return n * (M2**2) * (math.log(M2 / (mu**2)) - c) / (64 * math.pi**2)
    def V_one_loop(H, p):
        ms = masses_sq(H, p)
        mu = p["mu"]
        Vb = (
            loop_term(ms["M_H2"], 1, mu) +
            loop_term(ms["M_G2"], 1, mu) +
            loop_term(ms["M_A2"], 3, mu)
        )
        Vf = -loop_term(ms["M_psi2"], 4, mu)
        return Vb + Vf
    def V_tree(H, p):
        return 0.5 * p["m2"] * H**2 + 0.25 * p["lambda_H"] * H**4
    def V_eff(H, p):
        return V_tree(H, p) + V_one_loop(H, p)
    def dV(H, p, eps=1e-6):
        return (V_eff(H+eps, p) - V_eff(H-eps, p)) / (2*eps)
    def d2V(H, p, eps=1e-4):
        return (V_eff(H+eps, p) - 2*V_eff(H, p) + V_eff(H-eps, p)) / (eps**2)

# ---------------------------
# Two-loop RG (schematic)
# ---------------------------
def beta_two_loop(g, y, lam):
    """
    Schematic two-loop beta functions.
    Replace coefficients with exact values for your model.
    Returns (beta_g, beta_y, beta_lam).
    """
    # One-loop pieces (schematic)
    b_g1 = -7.0
    a_y1 = 3.0
    c_y1 = 3.0

    beta_g1 = b_g1 * g**3 / (16 * math.pi**2)
    beta_y1 = y * (a_y1 * y**2 - c_y1 * g**2) / (16 * math.pi**2)
    beta_lam1 = (3*lam**2 + 4*lam*y**2 - 8*y**4 - 6*lam*g**2 + 3*g**4) / (16 * math.pi**2)

    # Two-loop schematic corrections (small)
    # These are placeholders; real two-loop terms can be significant.
    beta_g2 = -3.0 * g**5 / (16 * math.pi**2)**2
    beta_y2 = -2.0 * y**5 / (16 * math.pi**2)**2
    beta_lam2 = -10.0 * y**6 / (16 * math.pi**2)**2

    return beta_g1 + beta_g2, beta_y1 + beta_y2, beta_lam1 + beta_lam2

def integrate_rg_two_loop(mu0, mu_max, params, steps=500):
    """
    Integrate two-loop RG using solve_ivp on d/d ln mu.
    Returns trace and mu_instability (first mu where lambda <= 0).
    """
    def rhs(lnmu, yvec):
        g, y, lam = yvec
        bg, by, bl = beta_two_loop(g, y, lam)
        return [bg, by, bl]

    y0 = [params["g"], params["y"], params["lambda_H"]]
    ln_mu0 = math.log(mu0)
    ln_mu_max = math.log(mu_max)
    t_eval = np.linspace(ln_mu0, ln_mu_max, steps)
    sol = solve_ivp(rhs, (ln_mu0, ln_mu_max), y0, t_eval=t_eval, method="RK45", rtol=1e-6, atol=1e-9)
    mus = np.exp(sol.t)
    gs, ys, lams = sol.y
    mu_inst = None
    for mu, lam in zip(mus, lams):
        if lam <= 0:
            mu_inst = mu
            break
    trace = {"mu": mus.tolist(), "g": gs.tolist(), "y": ys.tolist(), "lambda": lams.tolist()}
    return trace, mu_inst

# ---------------------------
# Vacuum tunneling (bounce action) - thin-wall and numerical shooting
# ---------------------------
def bounce_action_1d(Vfunc, phi_false, phi_true):
    """
    Compute O(4)-symmetric bounce action using shooting method.
    Vfunc(phi) returns potential energy density.
    This is a robust but computationally heavy routine; it uses a simple shooting solver.
    """
    # Define radial ODE: phi'' + (3/r) phi' = dV/dphi
    def ode_system(r, y):
        phi, phipr = y
        dphidr = phipr
        dphipdr = Vfunc.derivative(phi) - (3.0 / r) * phipr if r > 0 else Vfunc.derivative(phi)
        return [dphidr, dphipdr]

    # We implement a shooting from r=0 with phi(0)=phi0 ~ phi_true and adjust phi0 to reach phi_false at large r.
    # For stability, use a bounded bracket for phi0 between phi_true and phi_false.
    r_max = 100.0
    r_eval = np.linspace(1e-6, r_max, 2000)

    def shoot(phi0):
        # initial conditions
        y0 = [phi0, 0.0]
        sol = solve_ivp(lambda r, y: [y[1], Vfunc.derivative(y[0]) - (3.0/r)*y[1] if r>0 else Vfunc.derivative(y[0])],
                        (1e-6, r_max), y0, t_eval=r_eval, method="RK45", rtol=1e-6, atol=1e-9)
        phi_end = sol.y[0, -1]
        return phi_end, sol

    # bracket phi0
    low = phi_true
    high = phi_false
    try:
        # find phi0 such that phi_end ~ phi_false
        def objective(phi0):
            phi_end, _ = shoot(phi0)
            return phi_end - phi_false
        phi0_root = brentq(objective, low, high, xtol=1e-6, maxiter=50)
        _, sol = shoot(phi0_root)
        # compute action: S4 = 2*pi^2 * integral r^3 [1/2 phi'^2 + V(phi)] dr
        r = sol.t
        phi = sol.y[0]
        phipr = sol.y[1]
        integrand = 0.5 * phipr**2 + np.array([Vfunc.value(x) for x in phi])
        S4 = 2.0 * math.pi**2 * np.trapz(r**3 * integrand, r)
        return S4
    except Exception as e:
        log(f"[bounce] Shooting failed: {e}")
        return None

class PotentialWrapper:
    """
    Wraps V(phi) and provides derivative via finite difference.
    """
    def __init__(self, Vcallable):
        self.V = Vcallable
    def value(self, phi):
        return float(self.V(phi))
    def derivative(self, phi, eps=1e-6):
        return (self.V(phi+eps) - self.V(phi-eps)) / (2*eps)

# ---------------------------
# Finite-temperature effective potential (1-loop thermal)
# ---------------------------
def V_eff_thermal(H, p, T):
    """
    One-loop finite-temperature effective potential (high-T approx for bosons/fermions).
    Uses daisy resummation in a simple form (mass^2 -> mass^2 + c*T^2).
    """
    # Tree + zero-T one-loop
    p_local = p.copy()
    p_local["mu"] = max(1e-6, p.get("mu", 1.0))
    V0 = V_eff(H, p_local)

    # Thermal masses (schematic coefficients)
    # For scalar: c_s ~ (lambda/4 + y^2/6 + g^2/16) etc. Use simple model:
    c_s = 0.25 * p["lambda_H"] + 0.25 * p["y"]**2 + 0.1 * p["g"]**2
    mH2 = p["m2"] + 3*p["lambda_H"]*H**2 + c_s * T**2
    mG2 = p["m2"] + p["lambda_H"]*H**2 + c_s * T**2
    mpsi2 = (p["y"]*H)**2 + 0.0 * T**2
    mA2 = (p["g"]*H)**2 + 0.1 * T**2

    def J_b(m2_over_T2):
        # approximate bosonic thermal function (high-T expansion)
        x = m2_over_T2
        if x < 1e-6:
            return -math.pi**4 / 45.0 + math.pi**2/12.0 * x - math.pi/6.0 * x**1.5
        else:
            return -math.sqrt(2*math.pi) * x**1.5 * math.exp(-math.sqrt(x))

    def J_f(m2_over_T2):
        x = m2_over_T2
        if x < 1e-6:
            return -7.0*math.pi**4/360.0 + math.pi**2/24.0 * x
        else:
            return -math.sqrt(2*math.pi) * x**1.5 * math.exp(-math.sqrt(x))

    V_thermal = 0.0
    # bosons
    for m2, n in [(mH2,1),(mG2,1),(mA2,3)]:
        V_thermal += n * T**4 * J_b(max(0.0, m2 / (T**2)))
    # fermions
    V_thermal += -4 * T**4 * J_f(max(0.0, mpsi2 / (T**2)))

    return V0 + V_thermal

def find_critical_temperature(params, H_scan=(0.0, 10.0), T_min=0.0, T_max=500.0):
    """
    Find approximate critical temperature where symmetric and broken minima are degenerate.
    Scans T and finds T_c where V(0,T) ~ V(v(T),T).
    """
    def Vdiff(T):
        # find broken minimum at T
        p = params.copy()
        # coarse H scan
        Hs = np.linspace(H_scan[0], H_scan[1], 201)
        Vs = [V_eff_thermal(H, p, T) for H in Hs]
        idx = int(np.argmin(Vs))
        H_min = Hs[idx]
        V_min = Vs[idx]
        V0 = V_eff_thermal(0.0, p, T)
        return V_min - V0

    # bracket T where sign changes
    Ts = np.linspace(T_min, T_max, 101)
    vals = [Vdiff(T) for T in Ts]
    # find sign change
    for i in range(len(Ts)-1):
        if vals[i] * vals[i+1] <= 0:
            try:
                Tc = brentq(lambda T: Vdiff(T), Ts[i], Ts[i+1], xtol=1e-3)
                return Tc
            except Exception:
                continue
    return None

