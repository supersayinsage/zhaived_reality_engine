        g1 += betas["g1"] * dt
        g2 += betas["g2"] * dt
        g3 += betas["g3"] * dt
        y_u += betas["y_u"] * dt
        y_d += betas["y_d"] * dt
        y_e += betas["y_e"] * dt
        lam += betas["lambda_H"] * dt

