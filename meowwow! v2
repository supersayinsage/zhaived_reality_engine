def serious_scan(config):
    """
    High-resolution adaptive scan with checkpointing and parallel workers.
    Steps:
    - Generate initial coarse grid
    - Evaluate in parallel with evaluate_point_serious
    - Identify regions for refinement (phase boundaries, mu_inst gradients)
    - Refine up to max_refinements
    - Save checkpoint after each stage
    """
    # grid generation (coarse)
    lam_vals = np.linspace(config["lambda_H"]["min"], config["lambda_H"]["max"], config["lambda_H"]["points"])
    y_vals   = np.linspace(config["y"]["min"], config["y"]["max"], config["y"]["points"])
    g_vals   = np.linspace(config["g"]["min"], config["g"]["max"], config["g"]["points"])
    m2_vals  = np.linspace(config["m2"]["min"], config["m2"]["max"], config["m2"]["points"])

    # create list of parameter dicts
    grid = []
    for lam in lam_vals:
        for y in y_vals:
            for g in g_vals:
                for m2 in m2_vals:
                    grid.append({"lambda_H": float(lam), "y": float(y), "g": float(g), "m2": float(m2)})

    log(f"[serious_scan] Initial grid size: {len(grid)}")
    # parallel evaluation
    with mp.Pool(processes=config["parallel_workers"]) as pool:
        results = pool.map(evaluate_point_serious, grid)

    # checkpoint
    np.savez_compressed(CHECKPOINT_FILE, results=json.dumps(results))
    log(f"[serious_scan] Checkpoint saved: {CHECKPOINT_FILE}")

    # refinement logic: find points with mu_inst near threshold or phase boundary
    # For brevity, we do one refinement pass focusing on mu_inst within [1e6,1e12]
    to_refine = []
    for r in results:
        mu_inst = r["rg_mu_instability"]
        if mu_inst is not None and (1e6 <= mu_inst <= 1e12):
            to_refine.append(r["params"])

    log(f"[serious_scan] Points flagged for refinement: {len(to_refine)}")
    # build refined grid around flagged points
    refined = []
    for p in to_refine:
        lam_c = p["lambda_H"]; y_c = p["y"]; g_c = p["g"]; m2_c = p["m2"]
        lam_range = np.linspace(max(config["lambda_H"]["min"], lam_c*0.9), min(config["lambda_H"]["max"], lam_c*1.1), 9)
        y_range = np.linspace(max(config["y"]["min"], y_c*0.9), min(config["y"]["max"], y_c*1.1), 9)
        g_range = np.linspace(max(config["g"]["min"], g_c*0.9), min(config["g"]["max"], g_c*1.1), 9)
        m2_range = np.linspace(max(config["m2"]["min"], m2_c*1.1), min(config["m2"]["max"], m2_c*0.9), 9)
        for lam in lam_range:
            for y in y_range:
                for g in g_range:
                    for m2 in m2_range:
                        refined.append({"lambda_H": float(lam), "y": float(y), "g": float(g), "m2": float(m2)})
    # deduplicate
    seen = set()
    refined_unique = []
    for p in refined:
        key = (round(p["lambda_H"],8), round(p["y"],8), round(p["g"],8), round(p["m2"],8))
        if key not in seen:
            seen.add(key)
            refined_unique.append(p)
    log(f"[serious_scan] Refined unique points: {len(refined_unique)}")
    with mp.Pool(processes=config["parallel_workers"]) as pool:
        refined_results = pool.map(evaluate_point_serious, refined_unique)

    combined = results + refined_results
    # final checkpoint
    np.savez_compressed(CHECKPOINT_FILE, results=json.dumps(combined))
    log(f"[serious_scan] Final checkpoint saved: {CHECKPOINT_FILE}")
    return combined

