    """
    ln_mu0 = math.log(mu0)
    ln_mu_max = math.log(mu_max)
    t_vals = np.linspace(ln_mu0, ln_mu_max, steps)

    g1 = params["g1"]
    g2 = params["g2"]
    g3 = params["g3"]
    y_u = params["y_u"]
    y_d = params["y_d"]
    y_e = params["y_e"]
    lam = params["lambda_H"]

    mus = []
    g1s = []
    g2s = []
    g3s = []
    y_us = []
    y_ds = []
    y_es = []
    lams = []

    mu_inst = None

    for t in t_vals:
        mu = math.exp(t)
        mus.append(mu)
        g1s.append(g1)
        g2s.append(g2)
        g3s.append(g3)
        y_us.append(y_u)
        y_ds.append(y_d)
