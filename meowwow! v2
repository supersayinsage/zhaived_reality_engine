        # [SU(3)]^2 U(1)_Y: only color triplets contribute
        if Nc == 3:
            A_SU3_2Y += mult * Nw * Y
        # grav^2 U(1)_Y: sum of Y over all Weyl fermions
        A_grav2Y += mult * Nc * Nw * Y

    return {
        "U1Y_cubic": A_Y3,
        "SU2_sq_U1Y": A_SU2_2Y,
        "SU3_sq_U1Y": A_SU3_2Y,
        "grav_sq_U1Y": A_grav2Y
    }

