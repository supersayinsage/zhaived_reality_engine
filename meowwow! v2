def beta_one_loop(g: float, y: float, lam: float) -> Tuple[float, float, float]:
    """One-loop beta functions (schematic)."""
    b_g = -7.0
    a_y = 3.0
    c_y = 3.0
    
    beta_g = b_g * g**3 / (16 * math.pi**2)
    beta_y = y * (a_y * y**2 - c_y * g**2) / (16 * math.pi**2)
    beta_lam = (3*lam**2 + 4*lam*y**2 - 8*y**4 - 6*lam*g**2 + 3*g**4) / (16 * math.pi**2)
    
    return beta_g, beta_y, beta_lam

def beta_two_loop(g: float, y: float, lam: float) -> Tuple[float, float, float]:
    """Two-loop beta functions (schematic with placeholders)."""
    bg1, by1, bl1 = beta_one_loop(g, y, lam)
    
    # Two-loop schematic corrections
    bg2 = -3.0 * g**5 / (16 * math.pi**2)**2
    by2 = -2.0 * y**5 / (16 * math.pi**2)**2
    bl2 = -10.0 * y**6 / (16 * math.pi**2)**2
    
    return bg1 + bg2, by1 + by2, bl1 + bl2

def integrate_rg(mu0: float, mu_max: float, params: Dict[str, float],
                 two_loop: bool = True, steps: int = 500) -> Tuple[Dict, Optional[float]]:
    """Integrate RG equations using solve_ivp."""
    beta_func = beta_two_loop if two_loop else beta_one_loop
    
    def rhs(lnmu, yvec):
        g, y, lam = yvec
        bg, by, bl = beta_func(g, y, lam)
        return [bg, by, bl]
    
    y0 = [params["g"], params["y"], params["lambda_H"]]
    ln_mu0 = math.log(mu0)
    ln_mu_max = math.log(mu_max)
    t_eval = np.linspace(ln_mu0, ln_mu_max, steps)
    
    sol = solve_ivp(rhs, (ln_mu0, ln_mu_max), y0, t_eval=t_eval, method="RK45", rtol=1e-6, atol=1e-9)
    
    mus = np.exp(sol.t)
    gs, ys, lams = sol.y
    
    mu_inst = None
    for mu, lam in zip(mus, lams):
        if lam <= 0:
            mu_inst = mu
            break
    
    trace = {"mu": mus.tolist(), "g": gs.tolist(), "y": ys.tolist(), "lambda": lams.tolist()}
    return trace, mu_inst

