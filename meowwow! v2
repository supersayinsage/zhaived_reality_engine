def masses_sq(H: float, p: Dict[str, float]) -> Dict[str, float]:
    """Field-dependent masses squared."""
    return {
        "M_H2": p["m2"] + 3 * p["lambda_H"] * H**2,
        "M_G2": p["m2"] + p["lambda_H"] * H**2,
        "M_psi2": (p["y"] * H)**2,
        "M_A2": (p["g"] * H)**2,
    }

def loop_term(M2: float, n: int, mu: float, c: float = 1.5) -> float:
    """One-loop Coleman-Weinberg term."""
    if M2 <= 0:
        M2 = abs(M2) + 1e-12
    return n * (M2**2) * (math.log(M2 / (mu**2)) - c) / (64 * math.pi**2)

def V_one_loop(H: float, p: Dict[str, float]) -> float:
    """One-loop effective potential correction."""
    ms = masses_sq(H, p)
    mu = p["mu"]
    Vb = (loop_term(ms["M_H2"], 1, mu) +
          loop_term(ms["M_G2"], 1, mu) +
          loop_term(ms["M_A2"], 3, mu))
    Vf = -loop_term(ms["M_psi2"], 4, mu)
    return Vb + Vf

def V_tree(H: float, p: Dict[str, float]) -> float:
    """Tree-level potential."""
    return 0.5 * p["m2"] * H**2 + 0.25 * p["lambda_H"] * H**4

def V_eff(H: float, p: Dict[str, float]) -> float:
    """Full one-loop effective potential."""
    return V_tree(H, p) + V_one_loop(H, p)

def dV(H: float, p: Dict[str, float], eps: float = 1e-6) -> float:
    """First derivative via finite difference."""
    return (V_eff(H + eps, p) - V_eff(H - eps, p)) / (2 * eps)

def d2V(H: float, p: Dict[str, float], eps: float = 1e-4) -> float:
    """Second derivative via finite difference."""
    return (V_eff(H + eps, p) - 2 * V_eff(H, p) + V_eff(H - eps, p)) / (eps**2)

