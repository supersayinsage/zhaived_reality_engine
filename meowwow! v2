def evaluate_point_serious(point):
    """
    Evaluate a single parameter point with:
    - high-resolution minimum finding
    - two-loop RG integration to 1e16
    - critical temperature estimate
    - bounce action estimate (if metastable)
    - GUT matching stub
    """
    p = {
        "lambda_H": float(point["lambda_H"]),
        "y": float(point["y"]),
        "g": float(point["g"]),
        "m2": float(point["m2"]),
        "mu": 1.0
    }
    # high-res minimum: use local minimization starting from tree guess
    try:
        v_guess = math.sqrt(abs(p["m2"]) / p["lambda_H"])
    except Exception:
        v_guess = 1.0
    def V_local(H):
        return float(V_eff(H, p))
    # bracket search for minimum near v_guess
    try:
        res = minimize(lambda x: V_local(x[0]), x0=[v_guess], bounds=[(0.0, 50.0)], method="L-BFGS-B")
        H_min = float(res.x[0])
        V_min = float(res.fun)
    except Exception:
        # fallback coarse scan
        scan = find_minimum_scan_local(p, H_max=50.0, H_step=0.02)
        H_min = scan["H_min"]; V_min = scan["V_min"]

    # masses
    try:
        m_H = math.sqrt(abs(d2V(H_min, p)))
    except Exception:
        m_H = None
    m_psi = p["y"] * H_min
    m_A = p["g"] * H_min

    # two-loop RG
    rg_trace, mu_inst = integrate_rg_two_loop(1.0, 1e16, p, steps=800)

    # thermal critical temperature
    Tc = find_critical_temperature(p, H_scan=(0.0, max(5.0, H_min*2.0)), T_min=0.0, T_max=1000.0)

    # bounce action if metastable (lambda crosses zero below mu_max)
    bounce_S4 = None
    if mu_inst is not None and H_min > 1e-6:
        # build 1D potential wrapper along H direction between false vacuum (0) and true vacuum (H_min)
        Vwrap = PotentialWrapper(lambda phi: V_eff(phi, p))
        bounce_S4 = bounce_action_1d(Vwrap, phi_false=0.0, phi_true=H_min)

    gut = gut_matching_stub(p)

    result = {
        "params": p,
        "H_min": H_min,
        "V_min": V_min,
        "masses": {"H": m_H, "psi": m_psi, "A": m_A},
        "rg_mu_instability": mu_inst,
        "rg_trace_sample": {
            "mu": rg_trace["mu"][:: max(1, len(rg_trace["mu"])//80)],
            "lambda": rg_trace["lambda"][:: max(1, len(rg_trace["lambda"])//80)],
            "y": rg_trace["y"][:: max(1, len(rg_trace["y"])//80)],
            "g": rg_trace["g"][:: max(1, len(rg_trace["g"])//80)]
        },
        "Tc": Tc,
        "bounce_S4": bounce_S4,
        "gut": gut
    }
    return result

def find_minimum_scan_local(params, H_max=50.0, H_step=0.02):
    H_values = np.arange(0.0, H_max + H_step, H_step)
    V_values = [V_eff(H, params) for H in H_values]
    idx = int(np.argmin(V_values))
    H_min = float(H_values[idx])
    V_min = float(V_values[idx])
    return {"H_min": H_min, "V_min": V_min}

