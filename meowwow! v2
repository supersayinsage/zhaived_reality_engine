def unit_tests():
    """
    Run a small suite of unit tests to validate numerical stability and consistency.
    """
    tests = []
    # Test 1: V_eff finite at H=0 for baseline params
    p = {"m2": -1.0, "lambda_H": 0.1, "y": 0.6, "g": 0.3, "mu": 1.0}
    try:
        v0 = V_eff(0.0, p)
        tests.append(("V_eff_at_zero", True, v0))
    except Exception as e:
        tests.append(("V_eff_at_zero", False, str(e)))

    # Test 2: d2V positive at tree VEV for small couplings
    try:
        v_tree = math.sqrt(abs(p["m2"]) / p["lambda_H"])
        curv = d2V(v_tree, p)
        tests.append(("curvature_tree_positive", curv > 0, curv))
    except Exception as e:
        tests.append(("curvature_tree_positive", False, str(e)))

    # Test 3: RG integration stability (no NaNs)
    try:
        trace, mu_inst = integrate_rg_two_loop(1.0, 1e8, p, steps=200)
        ok = not any(math.isnan(x) for x in trace["lambda"])
        tests.append(("rg_no_nans", ok, {"mu_inst": mu_inst}))
    except Exception as e:
        tests.append(("rg_no_nans", False, str(e)))

    # Save tests
    with open(os.path.join(OUT_DIR, "unit_tests.json"), "w") as f:
        json.dump(tests, f, indent=2)
    log("[unit_tests] Completed and saved.")
    return tests

