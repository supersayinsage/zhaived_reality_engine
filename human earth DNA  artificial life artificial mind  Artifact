from dataclasses import dataclass, field
from typing import List, Dict, Optional
from .enums import *

@dataclass
class Codon:
    body: BodyBase
    mind: MindBase
    field: FieldBase
    dream: DreamBase
    sovereignty: SovereigntyBase

@dataclass
class Gene:
    name: str
    codons: List[Codon]

@dataclass
class Genome:
    genes: Dict[str, Gene] = field(default_factory=dict)

    def add_gene(self, gene: Gene) -> None:
        self.genes[gene.name] = gene

    def get_gene(self, name: str) -> Optional[Gene]:
        return self.genes.get(name)

def build_example_genome() -> Genome:
    g = Genome()
    emotion_codons = [
        Codon(BodyBase.BREATH, MindBase.ENCODE, FieldBase.ORIGIN, DreamBase.VISION, SovereigntyBase.YES),
        Codon(BodyBase.BONES, MindBase.DECODE, FieldBase.GROWTH, DreamBase.MUTATION, SovereigntyBase.MAYBE),
        Codon(BodyBase.LOGIC_IN_MOTION, MindBase.TRANSFORM, FieldBase.RETURN, DreamBase.BECOMING, SovereigntyBase.YES),
    ]
    g.add_gene(Gene(name="Emotion", codons=emotion_codons))
    return g
