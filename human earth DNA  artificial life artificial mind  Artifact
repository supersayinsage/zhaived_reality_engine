from dataclasses import dataclass, field
from typing import List, Dict, Any
import random
from .language import Vocabulary

@dataclass
class GroupGoal:
    type: str
    urgency: float
    satisfaction: float

@dataclass
class GroupEpisode:
    state_before: Dict
    action: str
    state_after: Dict
    timestamp: int

@dataclass
class CollectiveMind:
    id: int
    member_ids: List[int] = field(default_factory=list)
    avg_mood: float = 0.5
    population: int = 0
    resources: float = 0.0
    tech_level: float = 0.1
    conflict_index: float = 0.0
    goals: List[GroupGoal] = field(default_factory=lambda: [
        GroupGoal("STABILIZE", 0.0, 0.0),
        GroupGoal("EXPAND", 0.0, 0.0),
        GroupGoal("RESOURCE_GAIN", 0.0, 0.0)
    ])
    memory: List[GroupEpisode] = field(default_factory=list)
    culture: "Culture" = None
    government: "Government" = None
    medicine_level: float = 0.0
    language: Dict[str, float] = field(default_factory=dict)
    stories: List[str] = field(default_factory=list)

def aggregate_collective_state(civ: CollectiveMind, world: "World") -> None:
    members = [world.humans[i] for i in civ.member_ids if i in world.humans]
    if not members:
        civ.population = 0
        civ.avg_mood = 0.5
        civ.resources = 0.0
        return
    civ.population = len(members)
    civ.avg_mood = sum(h.mind.self_state.mood_state for h in members) / civ.population
    civ.resources = sum(h.mind.resources for h in members)
    # conflict index simplified
    civ.conflict_index = max(0, 1 - civ.avg_mood)

def evaluate_group_goals(civ: CollectiveMind) -> None:
    for g in civ.goals:
        if g.type == "STABILIZE":
            g.urgency = 1.0 - civ.avg_mood
        elif g.type == "EXPAND":
            g.urgency = civ.resources / (civ.population + 1)
        elif g.type == "RESOURCE_GAIN":
            g.urgency = 1.0 - (civ.resources / (civ.population + 1))

def choose_group_action(civ: CollectiveMind) -> str:
    urgencies = {g.type: g.urgency for g in civ.goals}
    return max(urgencies, key=urgencies.get)

def apply_group_action(civ: CollectiveMind, world: "World", action: str) -> None:
    if action == "STABILIZE":
        world.policies[civ.id] = world.policies.get(civ.id, {})
        world.policies[civ.id]["migration_bias"] = -0.2
    elif action == "EXPAND":
        world.policies[civ.id] = world.policies.get(civ.id, {})
        world.policies[civ.id]["migration_bias"] = 0.3
    elif action == "RESOURCE_GAIN":
        world.policies[civ.id] = world.policies.get(civ.id, {})
        world.policies[civ.id]["resource_pressure"] = world.policies[civ.id].get("resource_pressure", 0) + 0.1

def update_collective_mind(civ: CollectiveMind, world: "World") -> None:
    aggregate_collective_state(civ, world)
    evaluate_group_goals(civ)
    action = choose_group_action(civ)
    apply_group_action(civ, world, action)
    # update tech, language, etc.
    from .technology import update_tech
    from .language import update_civilization_language
    update_tech(civ)
    update_civilization_language(civ, world)
