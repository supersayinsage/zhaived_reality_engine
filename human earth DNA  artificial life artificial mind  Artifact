@dataclass
class CivilizationLayer:
    culture: float = 0.1
    tech: float = 0.1
    networks: float = 0.1
    memory: float = 0.1

    def step(self, region_temp: float, region_resources: float) -> None:
        self.culture += 0.001 * region_resources
        self.tech += 0.001 * (1 - abs(region_temp - 18) / 30)
        self.networks += 0.001
        self.memory += 0.0005

    def stage(self) -> str:
        score = (self.culture + self.tech + self.networks + self.memory) / 4
        if score < 0.2:
            return "Tribal"
        elif score < 0.5:
            return "Agrarian"
        elif score < 0.8:
            return "Industrial"
        else:
            return "Networked"

