from dataclasses import dataclass, field
from typing import List, Dict, Optional, Any
import random
import copy
from ..core.lattice import HazelTrinityLattice
from ..core.enums import EmotionBase
from .emotions import EmotionState, update_emotions, emotion_bias
from .goals import Goal, evaluate_goals
from .memory import Episode
from .language import Vocabulary

@dataclass
class SelfState:
    body_state: float = 1.0
    mood_state: float = 0.5
    social_status: float = 0.5
    security_level: float = 0.5
    autonomy_level: float = 0.5

@dataclass
class HumanMind:
    active_goals: List[Goal] = field(default_factory=list)
    episodes: List[Episode] = field(default_factory=list)
    action_values: Dict[str, float] = field(default_factory=lambda: {
        "MIGRATE": 0.5, "REST": 0.5, "GATHER": 0.5,
        "SOCIALIZE": 0.5, "EXPLORE": 0.5
    })
    self_state: SelfState = field(default_factory=SelfState)
    emotions: EmotionState = field(default_factory=EmotionState)
    resources: float = 0.5
    position: Tuple[int, int] = (0, 0)
    infected: Optional["Disease"] = None
    health: float = 1.0
    religion: Optional["Religion"] = None
    vocabulary: Vocabulary = field(default_factory=Vocabulary)

@dataclass
class HumanBeing:
    id: int
    lattice: HazelTrinityLattice
    mind: HumanMind = field(default_factory=HumanMind)

    def step(self, world: "World") -> None:
        self.lattice.step()
        # synchronize lattice mood with mind's mood (example)
        self.mind.self_state.mood_state = {
            EmotionBase.CALM: 0.7, EmotionBase.TENSION: 0.3, EmotionBase.RELEASE: 0.5
        }.get(self.lattice.state.mood, 0.5)
        update_human_mind(self, world, dt=1)

# ---- Action functions ----
def migrate(h: HumanBeing, world: "World") -> bool:
    x, y = h.mind.position
    dx = random.choice([-1,0,1])
    dy = random.choice([-1,0,1])
    nx = max(0, min(world.width-1, x+dx))
    ny = max(0, min(world.height-1, y+dy))
    h.mind.position = (nx, ny)
    return True

def rest(h: HumanBeing, world: "World") -> bool:
    h.mind.self_state.body_state += 0.05
    h.mind.self_state.mood_state += 0.02
    return True

def gather(h: HumanBeing, world: "World") -> float:
    x, y = h.mind.position
    amount = min(0.1, world.env.resource_map[y][x])
    world.env.resource_map[y][x] -= amount
    h.mind.resources += amount
    return amount

def socialize(h: HumanBeing, world: "World") -> float:
    neighbors = world.get_neighbors(h.mind.position)
    if not neighbors:
        return 0.0
    bond_gain = 0.02 * len(neighbors)
    h.mind.self_state.mood_state += bond_gain
    # Communicate
    for other in neighbors:
        from .language import communicate
        communicate(h, other)
    return bond_gain

def explore(h: HumanBeing, world: "World") -> bool:
    h.mind.self_state.mood_state += random.uniform(0.01, 0.03)
    return True

def choose_action(h: HumanBeing) -> str:
    weighted = {}
    for action, val in h.mind.action_values.items():
        weighted[action] = val * (1 + sum(g.urgency for g in h.mind.active_goals))
    return max(weighted, key=weighted.get)

def apply_action(h: HumanBeing, world: "World", action: str, dt: float) -> Dict[str, Any]:
    outcome = {}
    if action == "MIGRATE":
        outcome["moved"] = migrate(h, world)
    elif action == "REST":
        outcome["rest"] = rest(h, world)
    elif action == "GATHER":
        outcome["resources"] = gather(h, world)
    elif action == "SOCIALIZE":
        outcome["social_gain"] = socialize(h, world)
    elif action == "EXPLORE":
        outcome["explore"] = explore(h, world)
    return outcome

def compute_mood_change(h: HumanBeing, outcome: Dict) -> float:
    # simplified
    return sum(v for v in outcome.values() if isinstance(v, float)) * 0.1

def compute_resource_change(h: HumanBeing, outcome: Dict) -> float:
    return outcome.get("resources", 0.0)

def update_action_values(h: HumanBeing, episode: Episode) -> None:
    reward = episode.delta_mood + episode.delta_resources
    old = h.mind.action_values[episode.action]
    h.mind.action_values[episode.action] = old + 0.1 * (reward - old)

def observe(h: HumanBeing, world: "World") -> Dict:
    x,y = h.mind.position
    return {
        "temp": world.env.temperature_map[y][x],
        "resources": world.env.resource_map[y][x],
        "neighbors": len(world.get_neighbors((x,y)))
    }

def update_human_mind(h: HumanBeing, world: "World", dt: float) -> None:
    evaluate_goals(h.mind.active_goals)
    action = choose_action(h)
    outcome = apply_action(h, world, action, dt)
    episode = Episode(
        situation=observe(h, world),
        action=action,
        outcome=str(outcome),
        delta_mood=compute_mood_change(h, outcome),
        delta_resources=compute_resource_change(h, outcome),
        timestamp=world.time
    )
    h.mind.episodes.append(episode)
    update_action_values(h, episode)
    update_emotions(h.mind, outcome)
    emotion_bias(h.mind, h.mind.action_values)

    # reproduction & death
    try_reproduce(h, world)
    if check_death(h):
        world.mark_for_death(h.id)

def try_reproduce(h: HumanBeing, world: "World") -> None:
    if h.mind.resources > 0.8 and h.mind.self_state.mood_state > 0.6:
        if random.random() < 0.01:
            spawn_child(h, world)

def spawn_child(parent: HumanBeing, world: "World") -> HumanBeing:
    child = copy.deepcopy(parent)
    child.id = world.next_human_id()
    child.mind.resources = 0.3
    mutate_traits(child)
    world.humans.append(child)
    return child

def mutate_traits(h: HumanBeing) -> None:
    for k in h.mind.action_values:
        h.mind.action_values[k] += random.uniform(-0.05, 0.05)
        h.mind.action_values[k] = max(0.1, min(1.0, h.mind.action_values[k]))

def check_death(h: HumanBeing) -> bool:
    if h.mind.resources <= 0 or h.mind.self_state.body_state <= 0:
        return True
    return False
