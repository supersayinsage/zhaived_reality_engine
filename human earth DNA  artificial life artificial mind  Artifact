@dataclass
class Region:
    id: int
    name: str
    lat: float
    lon: float
    biome: Biome
    civilization: CivilizationLayer = field(default_factory=CivilizationLayer)

    temperature: float = 15.0
    resources: float = 1.0
    humans: List[HumanBeing] = field(default_factory=list)
    populations: List[Population] = field(default_factory=list)

    def step(self, time_hours: float) -> None:
        day_phase = math.sin(time_hours * 2 * math.pi / 24.0)
        year_phase = math.sin(time_hours * 2 * math.pi / (24.0 * 365.0))

        self.temperature = (
            self.biome.base_temp
            + self.biome.day_variation * day_phase
            + self.biome.season_variation * year_phase
        )

        weather = random.uniform(-3, 3)
        self.temperature += weather

        self.resources = max(
            0.0,
            min(
                1.0,
                self.resources + random.uniform(-0.01, 0.02) * self.biome.resource_factor
            )
        )

        for p in self.populations:
            p.step(self.resources)

        self.civilization.step(self.temperature, self.resources)
        stage = self.civilization.stage()
        if stage == "Industrial":
            self.resources -= 0.005
            self.temperature += 0.1
        elif stage == "Networked":
            self.resources += 0.003

# =========================
#  HUMAN BEING (SINGLE ORGANISM)
# =========================

@dataclass
class HumanBeing:
    id: int
    lattice: HazelTrinityLattice

    def step(self, regions: List[Region]) -> None:
        self.lattice.step()
        self._decide(regions)

    def _current_region(self, regions: List[Region]) -> Optional[Region]:
        for r in regions:
            if self in r.humans:
                return r
        return None

    def _decide(self, regions: List[Region]) -> None:
        current = self._current_region(regions)
        if not current:
            return

        comfort = (1 - abs(current.temperature - 18) / 40) + current.resources

        if comfort < 0.5:
            self._migrate(regions)
        else:
            current.civilization.step(current.temperature, current.resources)

    def _migrate(self, regions: List[Region]) -> None:
        if not regions:
            return
        best = max(
            regions,
            key=lambda r: (1 - abs(r.temperature - 18) / 40) + r.resources
        )
        for r in regions:
            if self in r.humans:
                r.humans.remove(self)
        best.humans.append(self)

# =========================
#  PLANET BEING (EARTH-MIRROR)
# =========================

@dataclass
class PlanetBeing:
    name: str = "Earth-Mirror"
    regions: List[Region] = field(default_factory=list)
    humans: List[HumanBeing] = field(default_factory=list)

    age_hours: float = 0.0
    emotion_state: EmotionBase = EmotionBase.CALM
    time_state: TimeBase = TimeBase.NOW

    def step(self) -> None:
        self.age_hours += 1.0

        for r in self.regions:
            r.step(self.age_hours)

        for h in self.humans:
            h.step(self.regions)

        self._update_emotion()
        self._update_time_state()

    def _update_emotion(self) -> None:
        moods = [h.lattice.state.mood for h in self.humans]
        temps = [r.temperature for r in self.regions]

        if not moods:
            self.emotion_state = EmotionBase.CALM
            return

        calm = moods.count(EmotionBase.CALM)
        tension = moods.count(EmotionBase.TENSION)
        release = moods.count(EmotionBase.RELEASE)
        avg_temp = sum(temps) / len(temps) if temps else 15.0

        if tension > calm and avg_temp > 20:
            self.emotion_state = EmotionBase.TENSION
        elif calm >= tension and 5 < avg_temp < 25:
            self.emotion_state = EmotionBase.CALM
        else:
            self.emotion_state = EmotionBase.RELEASE

    def _update_time_state(self) -> None:
        if self.age_hours < 24 * 365:
            self.time_state = TimeBase.BEFORE
        elif self.age_hours < 24 * 365 * 100:
            self.time_state = TimeBase.NOW
        else:
            self.time_state = TimeBase.AFTER

    def speak(self) -> str:
        return (
            f"[{self.name}] AGE={self.age_hours:.0f}H "
            f"EMO={self.emotion_state.name} HUMANS={len(self.humans)}"
        )

