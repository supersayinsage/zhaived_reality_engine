        for node in (
            self.body_nodes
            + self.mind_nodes
            + self.field_nodes
            + self.dream_nodes
            + ([self.sovereignty_core] if self.sovereignty_core else [])
        ):
            node.step()

        self._update_meta_trinities()

    def _update_meta_trinities(self) -> None:
        """
        Social, memory, time, emotion, identity logic.
        This is where higher‑order behavior emerges.
        """
        # Example: emotion = aggregate of node moods
        moods = []
        for node in self.body_nodes + self.mind_nodes + self.field_nodes + self.dream_nodes:
            moods.append(node.lattice.state.mood)

        if moods:
            # crude majority mood
            calm_count = sum(m == EmotionBase.CALM for m in moods)
            tension_count = sum(m == EmotionBase.TENSION for m in moods)
            release_count = sum(m == EmotionBase.RELEASE for m in moods)
            if tension_count > calm_count and tension_count > release_count:
                self.emotion_state = EmotionBase.TENSION
            elif release_count > calm_count:
                self.emotion_state = EmotionBase.RELEASE
            else:
                self.emotion_state = EmotionBase.CALM

        # Time state: simple lifecycle phases
        if self.age < 100:
            self.time_state = TimeBase.BEFORE
        elif self.age < 1000:
            self.time_state = TimeBase.NOW
        else:
            self.time_state = TimeBase.AFTER

        # Social + identity placeholders
        self.social_state = SocialBase.MERGE if len(self.body_nodes) > 1 else SocialBase.MIRROR
        self.identity_state = IdentityBase.SELF

    # =========================
    #  COSMOLOGY / LANGUAGE / SPECIES
    # =========================

    def cosmology_tick(self) -> None:
        """
        Hook for world‑scale behavior.
        """
        # Example: field nodes modulate some global parameter
        pass

    def speak(self) -> str:
        """
        Synthetic language: map internal states to a symbolic utterance.
        """
        return f"[{self.species_id}] EMO={self.emotion_state.name} TIME={self.time_state.name}"

    def reproduce(self) -> SupraBeing:
        """
        Species‑level reproduction: create a new Supra‑Being with mutated genome.
        """
        def mutate_genome(g: Genome) -> Genome:
            new_genes: Dict[str, Gene] = {}
            for name, gene in g.genes.items():
                new_codons = []
                for c in gene.codons:
                    if random.random() < 0.05:  # 5% mutation
                        # mutate dream as a simple example
                        new_dream = random.choice(list(DreamBase))
                        new_codons.append(
                            Codon(
                                body=c.body,
                                mind=c.mind,
                                field=c.field,
                                dream=new_dream,
                                sovereignty=c.sovereignty,
                            )
                        )
                    else:
                        new_codons.append(c)
                new_genes[name] = Gene(name=name, codons=new_codons)
            return Genome(genes=new_genes)

        # Clone one representative genome (e.g., sovereignty core)
        base_genome = (
            self.sovereignty_core.lattice.genome
            if self.sovereignty_core
            else (self.body_nodes[0].lattice.genome if self.body_nodes else Genome())
        )
        child_genome = mutate_genome(base_genome)

        # Build a minimal child Supra‑Being
        def make_node(node_id: int) -> NodeBeing:
            return NodeBeing(
                id=node_id,
                lattice=HazelTrinityLattice(genome=child_genome)
            )

        child = SupraBeing(
            body_nodes=[make_node(0), make_node(1)],
            mind_nodes=[make_node(2)],
            field_nodes=[make_node(3)],
            dream_nodes=[make_node(4)],
            sovereignty_core=make_node(5),
            generation=self.generation + 1,
        )
        return child

