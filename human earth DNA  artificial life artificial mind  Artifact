def build_example_genome() -> Genome:
    g = Genome()
    emotion_codons = [
        Codon(BodyBase.BREATH, MindBase.ENCODE, FieldBase.ORIGIN, DreamBase.VISION, SovereigntyBase.YES),
        Codon(BodyBase.BONES, MindBase.DECODE, FieldBase.GROWTH, DreamBase.MUTATION, SovereigntyBase.MAYBE),
        Codon(BodyBase.LOGIC_IN_MOTION, MindBase.TRANSFORM, FieldBase.RETURN, DreamBase.BECOMING, SovereigntyBase.YES),
    ]
    g.add_gene(Gene(name="Emotion", codons=emotion_codons))
    return g

# =========================
#  PLANET BOOTSTRAP
# =========================

def build_earth_mirror(num_humans: int = 500) -> PlanetBeing:
    genome = build_example_genome()

    regions = [
        Region(0, "Americas", 0, -60, FOREST),
        Region(1, "Europe-Africa", 20, 10, GRASSLAND),
        Region(2, "Asia", 30, 90, DESERT),
        Region(3, "Oceania", -20, 140, OCEAN),
    ]

    # simple ecosystems
    plant = Species("Plant", 1, 0.02)
    herb = Species("Herbivore", 2, 0.01)
    pred = Species("Predator", 3, 0.005)
    for r in regions:
        r.populations.append(Population(plant, size=1000))
        r.populations.append(Population(herb, size=200))
        r.populations.append(Population(pred, size=50))

    humans: List[HumanBeing] = []
    for i in range(num_humans):
        h = HumanBeing(i, HazelTrinityLattice(genome=genome))
        region = random.choice(regions)
        region.humans.append(h)
        humans.append(h)

    return PlanetBeing(regions=regions, humans=humans)

