def choose_action(h):
    # Filter actions that satisfy urgent goals
    weighted_actions = {}
    for action, value in h.action_values.items():
        goal_factor = sum(g.urgency for g in h.active_goals)
        weighted_actions[action] = value * (1.0 + goal_factor)

    # Pick the highest-value action
    return max(weighted_actions, key=weighted_actions.get)
