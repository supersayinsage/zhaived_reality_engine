from dataclasses import dataclass, field
from typing import List, Dict

@dataclass
class PlanetGoal:
    type: str
    urgency: float
    satisfaction: float

@dataclass
class PlanetEpisode:
    global_state_before: Dict
    action: str
    global_state_after: Dict
    timestamp: int

@dataclass
class PlanetaryMind:
    goals: List[PlanetGoal] = field(default_factory=lambda: [
        PlanetGoal("MAINTAIN_DIVERSITY", 0.0, 0.0),
        PlanetGoal("LIMIT_CHAOS", 0.0, 0.0)
    ])
    history: List[PlanetEpisode] = field(default_factory=list)

def read_global_state(world: "World") -> Dict:
    moods = [h.mind.self_state.mood_state for h in world.humans]
    avg_mood = sum(moods)/len(moods) if moods else 0.5
    return {
        "population": len(world.humans),
        "avg_mood": avg_mood,
        "biodiversity": world.env.biodiversity,
        "instability": world.env.instability_index
    }

def evaluate_planet_goals(pm: PlanetaryMind, global_state: Dict) -> None:
    for g in pm.goals:
        if g.type == "MAINTAIN_DIVERSITY":
            g.urgency = 1.0 - global_state["biodiversity"]
        elif g.type == "LIMIT_CHAOS":
            g.urgency = global_state["instability"]

def choose_planet_action(pm: PlanetaryMind) -> str:
    urgencies = {g.type: g.urgency for g in pm.goals}
    return max(urgencies, key=urgencies.get)

def apply_planet_action(world: "World", action: str) -> None:
    if action == "MAINTAIN_DIVERSITY":
        world.env.resource_regen_rate *= 1.05
    elif action == "LIMIT_CHAOS":
        world.env.disaster_frequency *= 0.9

def update_planetary_mind(pm: PlanetaryMind, world: "World") -> None:
    state_before = read_global_state(world)
    evaluate_planet_goals(pm, state_before)
    action = choose_planet_action(pm)
    apply_planet_action(world, action)
    state_after = read_global_state(world)
    pm.history.append(PlanetEpisode(state_before, action, state_after, world.time))
