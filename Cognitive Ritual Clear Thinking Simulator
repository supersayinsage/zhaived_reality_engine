# ============================================================

# GAME EXECUTION

# ============================================================

 

def execute_command(state: GameState, renderer: Renderer, cmd: Command) -> bool:

    """

    Execute a command.

    Returns False if the simulator should exit, True otherwise.

    """

    name = cmd.name

    arg = cmd.arg

 

    if name == "noop":

        return True

 

    if name == "quit":

        print("Goodbye.")

        return False

 

    if name == "help":

        renderer.render_help()

        return True

 

    if name == "settings":

        renderer.render_settings()

        return True

 

    if name == "set":

        if not arg:

            print("Usage: set depth <n> | set verbosity <low|medium|high>")

            return True

        parts = arg.split()

        if len(parts) != 2:

            print("Usage: set depth <n> | set verbosity <low|medium|high>")

            return True

        key, value = parts[0], parts[1]

        if key == "depth":

            try:

                d = int(value)

                state.depth = max(1, d)

                print(f"Depth set to {state.depth}")

            except ValueError:

                print("Depth must be an integer.")

        elif key == "verbosity":

            if value not in ("low", "medium", "high"):

                print("Verbosity must be one of: low, medium, high")

            else:

                state.verbosity = value

                print(f"Verbosity set to {state.verbosity}")

        else:

            print("Unknown setting. Use 'depth' or 'verbosity'.")

        return True

 

    if name == "think":

        if not arg:

            print("Usage: think <text>")

            return True

        result = run_symbolic_pipeline(state.engine, arg)

        state.last_result = result

        rec = RunRecord(

            id=str(uuid.uuid4())[:8],

            input_text=arg,

            result=result,

            timestamp=time.time(),

        )

        state.history.append(rec)

        renderer.render_summary_map()

        return True

 

    if name == "map":

        renderer.render_summary_map()

        return True

 

    if name == "recall":

        renderer.render_history()

        return True

 

    if name == "zoom":

        zone = (arg or "").lower()

        if zone == "axis":

            renderer.render_zoom_axis()

        elif zone == "tree":

            renderer.render_zoom_tree()

        elif zone in ("geom", "geometry"):

            renderer.render_zoom_geom()

        elif zone in ("fract", "fractal"):

            renderer.render_zoom_fract()

        elif zone == "heart":

            renderer.render_zoom_heart()

        elif zone == "pulse":

            renderer.render_zoom_pulse()

        elif zone in ("hex", "hexagram"):

            renderer.render_zoom_hex()

        elif zone == "fusion":

            renderer.render_zoom_fusion()

        else:

            print("Unknown zone. Use: axis, tree, geom, fract, heart, pulse, hex, fusion.")

        return True

 

    print("Unknown command. Type 'help' for a list of commands.")

    return True

def main() -> None:

    engine = build_symbolic_engine()

    state = GameState(engine=engine)

    renderer = Renderer(state)

    parser = CommandParser()

 

    renderer.render_banner()

 

    while True:

        try:

            raw = input("> ")

        except (EOFError, KeyboardInterrupt):

            print("\nGoodbye.")

            break

 

        cmd = parser.parse(raw)

        keep_going = execute_command(state, renderer, cmd)

        if not keep_going:

            break

if name == "__main__":

    main()































