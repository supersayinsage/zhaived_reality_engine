    def render_history(self, limit: int = 5) -> None:

        self._print_header("RECENT RUNS")

        if not self.state.history:

            print("No runs yet.")

            return

 

        for rec in self.state.history[-limit:]:

            ts = time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(rec.timestamp))

            print(f"- [{rec.id}] {ts}")

            print(f"  input: {self._wrap(rec.input_text, indent=4)}")

            axis = rec.result.get("axis", {})

            heart = rec.result.get("heart", {})

            print(f"  axis: {axis.get('alignment', 'n/a')}, heart: {heart.get('valence', 'n/a')}")

            print()

 

