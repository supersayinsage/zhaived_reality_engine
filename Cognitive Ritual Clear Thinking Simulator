@dataclass

class RunRecord:

    id: str

    input_text: str

    result: Dict[str, Any]

    timestamp: float

@dataclass

class GameState:

    engine: Any

    history: List[RunRecord] = field(default_factory=list)

    last_result: Optional[Dict[str, Any]] = None

    verbosity: str = "medium"  # low | medium | high

    depth: int = 3             # zoom depth

 

# ============================================================

# COMMAND PARSER

# ============================================================

 

@dataclass

class Command:

    name: str

    arg: Optional[str] = None

class CommandParser:

    @staticmethod

    def parse(raw: str) -> Command:

        raw = raw.strip()

        if not raw:

            return Command(name="noop")

 

        parts = raw.split(" ", 1)

        cmd = parts[0].lower()

        arg = parts[1].strip() if len(parts) > 1 else None

 

        if cmd in ("quit", "exit"):

            cmd = "quit"

 

        return Command(name=cmd, arg=arg)

 

