    def init(self, state: GameState) -> None:

        self.state = state

 

    def _wrap(self, text: str, width: int = 70, indent: int = 0) -> str:

        return textwrap.fill(

            text,

            width=width,

            initial_indent=" " * indent,

            subsequent_indent=" " * indent,

        )

 

    def printheader(self, title: str) -> None:

        print()

        print("=" * 60)

        print(title)

        print("=" * 60)

 

