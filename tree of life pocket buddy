class Button:
    def __init__(self, x, y, w, h, text):
        self.rect = pygame.Rect(x, y, w, h)
        self.text = text
        self.hovered = False
        self.visible = True
        self.font = pygame.font.Font(None, 24)
    
    def handle_event(self, event):
        if not self.visible:
            return False
        if event.type == pygame.MOUSEMOTION:
            self.hovered = self.rect.collidepoint(event.pos)
        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
            if self.hovered:
                return True
        return False
    
    def draw(self, surface):
        if not self.visible:
            return
        color = Colors.BUTTON_HOVER if self.hovered else Colors.BUTTON
        pygame.draw.rect(surface, color, self.rect, border_radius=8)
        text_surf = self.font.render(self.text, True, Colors.WHITE)
        text_rect = text_surf.get_rect(center=self.rect.center)
        surface.blit(text_surf, text_rect)

class TextBox:
    def __init__(self, x, y, w, h):
        self.rect = pygame.Rect(x, y, w, h)
        self.lines = []
        self.font = pygame.font.Font(None, 28)
        self.typing = False
        self.progress = 0
        self.target = []
        self.speed = 3
        self.callback = None
    
    def set_text(self, text, callback=None):
        if isinstance(text, str):
            self.target = self._wrap(text)
        else:
            self.target = text
        self.lines = []
        self.typing = True
        self.progress = 0
        self.callback = callback
    
    def _wrap(self, text):
        words = text.split()
        lines = []
        current = []
        for w in words:
            test = ' '.join(current + [w])
            if self.font.size(test)[0] < self.rect.width - 40:
                current.append(w)
            else:
                if current:
                    lines.append(' '.join(current))
                current = [w]
        if current:
            lines.append(' '.join(current))
        return lines
    
    def update(self):
        if self.typing and self.progress < len(' '.join(self.target)):
            self.progress += self.speed
            full = ' '.join(self.target)
            current = full[:min(int(self.progress), len(full))]
            self.lines = self._wrap(current)
        elif self.typing and self.progress >= len(' '.join(self.target)):
            self.typing = False
            if self.callback:
                self.callback()
    
    def draw(self, surface):
        bg = pygame.Surface((self.rect.width, self.rect.height), pygame.SRCALPHA)
        bg.fill(Colors.TEXT_BOX)
        surface.blit(bg, self.rect)
        pygame.draw.rect(surface, Colors.WHITE, self.rect, 2, border_radius=8)
        y = self.rect.y + 15
        for line in self.lines:
            surf = self.font.render(line, True, Colors.WHITE)
            surface.blit(surf, (self.rect.x + 20, y))
            y += 35

