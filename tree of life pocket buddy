            lines.append("⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️⚛️")
            lines.append("")
        else:
            lines.append("Recent Equations Found:")
            recent = [s for s in self.player.seals_collected if s != 81][-5:]
            for s in recent:
                eq = CODEX_SEALS[s]['title']
                dim = CODEX_SEALS[s]['dimension']
                lines.append(f"  - Seal {s}: {eq} ({dim})")
        
        self.textbox.set_text_instant("\n".join(lines))
    
    def _handle_button(self, name):
        if name == "new":
            self._start_new()
        elif name == "continue":
            self.scene = "game"
            self._show_title_btns(False)
            self._after_intro()
        elif name == "codex":
            self.scene = "codex"
            self.buttons["back"].visible = True
            self._update_codex_text()
        elif name == "quit":
            self.running = False
            self._save()
        elif name == "back":
            self.scene = "title"
            self.buttons["back"].visible = False
            self._show_title_btns(True)
    
    def _handle_events(self):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.running = False
                self._save()
            
            for name, btn in self.buttons.items():
                if btn.handle_event(event):
                    self._handle_button(name)
            
            for i, btn in enumerate(self.choice_btns):
                if btn.handle_event(event):
                    self._handle_choice(i)
    
    def _draw_title(self):
        self.screen.fill(Colors.BLACK)
        font = pygame.font.Font(None, 64)
        title = font.render("🧬 METRODIVIDIAN", True, Colors.COMPLETE_GOLD)
        self.screen.blit(title, title.get_rect(center=(SCREEN_WIDTH//2, 180)))
        
        font2 = pygame.font.Font(None, 32)
        subtitle = font2.render("Unified Field Theory Simulator", True, Colors.WHITE)
        self.screen.blit(subtitle, subtitle.get_rect(center=(SCREEN_WIDTH//2, 250)))
        
        font3 = pygame.font.Font(None, 24)
        desc = font3.render("Collect 81 equations. Descend through 9 dimensions. Discover the Theory of Everything.", True, Colors.GRAY)
        self.screen.blit(desc, desc.get_rect(center=(SCREEN_WIDTH//2, 310)))
        
        for btn in self.buttons.values():
            btn.draw(self.screen)
    
    def _draw_game(self):
        self.screen.blit(self.background, (0, 0))
        
        dim = DIMENSIONS.get(self.player.current_dimension, DIMENSIONS["Aether"])
        font = pygame.font.Font(None, 32)
        header = font.render(f"{dim['glyph']} {self.player.current_dimension}: {dim['name']}", True, Colors.WHITE)
        self.screen.blit(header, (50, 50))
        
        small = pygame.font.Font(None, 20)
        att_text = small.render(f"{'👁️'} Attn: {self.player.attention:.0f}%", True, Colors.WHITE)
        comp_text = small.render(f"{'🫂'} Comp: {self.player.compassion:.0f}%", True, Colors.WHITE)
        prog_text = small.render(f"{'📊'} Progress: {self.player.progress_to_unity():.0%}", True, Colors.WHITE)
        seal_text = small.render(f"{'📜'} Eqs: {len(self.player.seals_collected)}/81", True, Colors.WHITE)
        lvl_text = small.render(f"{'✨'} Level {self.player.level}", True, Colors.WHITE)
        
        self.screen.blit(att_text, (50, 90))
        self.screen.blit(comp_text, (50, 112))
        self.screen.blit(prog_text, (50, 134))
        self.screen.blit(seal_text, (50, 156))
        self.screen.blit(lvl_text, (50, 178))
        
        self.textbox.update()
        self.textbox.draw(self.screen)
        
        for btn in self.choice_btns:
            btn.draw(self.screen)
        for btn in self.buttons.values():
            btn.draw(self.screen)
    
    def _draw_codex(self):
        self.screen.fill(Colors.BLACK)
        font = pygame.font.Font(None, 48)
        title = font.render("📜 EQUATION ARCHIVE", True, Colors.COMPLETE_GOLD)
        self.screen.blit(title, title.get_rect(center=(SCREEN_WIDTH//2, 60)))
        
        self.textbox.draw(self.screen)
        for btn in self.buttons.values():
            btn.draw(self.screen)
    
    def draw(self):
        if self.scene == "title":
            self._draw_title()
        elif self.scene == "game":
            self._draw_game()
        elif self.scene == "codex":
            self._draw_codex()
        pygame.display.flip()
    
    def run(self):
        while self.running:
            self._handle_events()
            self.draw()
            self.clock.tick(FPS)
        pygame.quit()
        sys.exit()

