@dataclass
class Player:
    name: str = "Seeker"
    current_dimension: str = "Aether"
    attention: float = 100.0  # Your ability to measure/collapse
    compassion: float = 50.0  # Your ability to unify/cohere
    wisdom: float = 0.0
    level: int = 1
    seals_collected: List[int] = field(default_factory=list)
    
    def collect_seal(self, num: int) -> bool:
        if num not in self.seals_collected:
            self.seals_collected.append(num)
            self.seals_collected.sort()
            self.wisdom += 1.0
            # Every 9 seals unlocks new insight
            if len(self.seals_collected) % 9 == 0:
                self.level += 1
                self.compassion = min(100, self.compassion + 5)
                self.attention = min(100, self.attention + 5)
            return True
        return False
    
    def has_unified_theory(self) -> bool:
        return 81 in self.seals_collected
    
    def progress_to_unity(self) -> float:
        return len(self.seals_collected) / 81

