class MetrodividianGame:
    def __init__(self):
        self.running = True
        self.screen = SCREEN
        self.clock = pygame.time.Clock()
        self.player = Player()
        self.scene = "title"
        self.textbox = TextBox(100, SCREEN_HEIGHT - 250, SCREEN_WIDTH - 200, 200)
        self.current_char = None
        self.current_dialogue = []
        self.dialogue_index = 0
        self.awaiting_choice = False
        self.choice_options = []
        self.choice_btns = []
        
        self._load_save()
        self._create_buttons()
        self._update_bg()
    
    def _create_buttons(self):
        cx = SCREEN_WIDTH // 2
        self.buttons = {
            "new": Button(cx - 100, 350, 200, 50, "New Game"),
            "continue": Button(cx - 100, 420, 200, 50, "Continue"),
            "codex": Button(cx - 100, 490, 200, 50, "Codex"),
            "quit": Button(cx - 100, 560, 200, 50, "Quit"),
            "back": Button(50, SCREEN_HEIGHT - 80, 120, 40, "Back")
        }
        self.buttons["back"].visible = False
        for btn in self.buttons.values():
            btn.visible = False
        self.buttons["new"].visible = True
    
    def _update_bg(self):
        self.background = pygame.Surface((SCREEN_WIDTH, SCREEN_HEIGHT))
        realm = REALMS.get(self.player.current_realm, REALMS["Aether"])
        color = realm["color"]
        for y in range(SCREEN_HEIGHT):
            f = y / SCREEN_HEIGHT
            r = int(color[0] * (1 - f * 0.5))
            g = int(color[1] * (1 - f * 0.5))
            b = int(color[2] * (1 - f * 0.5))
            pygame.draw.line(self.background, (r, g, b), (0, y), (SCREEN_WIDTH, y))
    
    def _load_save(self):
        try:
            if os.path.exists("save.json"):
                with open("save.json", "r") as f:
                    data = json.load(f)
                    p = data.get("player", {})
                    self.player.seals_discovered = p.get("seals_discovered", [])
                    self.player.visited_realms = p.get("visited_realms", [])
                    self.player.wisdom = p.get("wisdom", 0)
                    self.player.level = p.get("level", 1)
        except:
            pass
    
    def _save(self):
        data = {"player": {
            "seals_discovered": self.player.seals_discovered,
            "visited_realms": self.player.visited_realms,
            "wisdom": self.player.wisdom,
            "level": self.player.level
        }}
        with open("save.json", "w") as f:
            json.dump(data, f)
    
    def _start_new(self):
        self.player = Player()
        self.scene = "game"
        self._show_title_btns(False)
        self._start_intro()
    
    def _show_title_btns(self, show):
        for n in ["new", "continue", "codex", "quit"]:
            self.buttons[n].visible = show
        self.buttons["back"].visible = not show
    
    def _start_intro(self):
        self.current_char = "kenji"
        self.current_dialogue = CHARACTERS["kenji"]["dialogue"]["greeting"].copy()
        self.dialogue_index = 0
        self._show_line()
    
    def _show_line(self):
        if self.dialogue_index < len(self.current_dialogue):
            self.textbox.set_text(self.current_dialogue[self.dialogue_index])
        else:
            self._after_dialogue()
    
    def _after_dialogue(self):
        if self.current_char == "kenji" and self.current_dialogue == CHARACTERS["kenji"]["dialogue"]["greeting"]:
            self.current_dialogue = CHARACTERS["kenji"]["dialogue"]["principles"]
            self.dialogue_index = 0
            self._show_line()
        elif self.current_char == "kenji" and self.current_dialogue == CHARACTERS["kenji"]["dialogue"]["principles"]:
            self._show_choices(["Explore Codex", "Visit a Realm", "Ask about Compassion", "Remain Silent"])
        else:
            self._show_realm_choices()
    
    def _show_choices(self, options):
        self.awaiting_choice = True
        self.choice_options = options
        self.choice_btns = []
        y = SCREEN_HEIGHT - 180
        for i, opt in enumerate(options):
            x = 200 + i * 250
            self.choice_btns.append(Button(x, y, 220, 50, opt))
    
    def _show_realm_choices(self):
        realms = list(REALMS.keys())
        self.choice_options = realms
        self.choice_btns = []
        y = SCREEN_HEIGHT - 200
        for i, r in enumerate(realms):
            x = 200 + (i % 3) * 250
            row = i // 3
            self.choice_btns.append(Button(x, y + row * 60, 220, 50, r))
        self.awaiting_choice = True
    
    def _handle_choice(self, idx):
        self.awaiting_choice = False
        self.choice_btns = []
        choice = self.choice_options[idx]
        
        if "Codex" in choice:
            self.scene = "codex"
            self.buttons["back"].visible = True
            self.textbox.set_text_instant(f"CODEX\nSeals: {len(self.player.seals_discovered)}/81\n\nRecent: {self.player.seals_discovered[-1] if self.player.seals_discovered else 'None'}")
        elif "Realm" in choice or choice in REALMS:
            self.player.current_realm = choice
            if choice not in self.player.visited_realms:
                self.player.visited_realms.append(choice)
            self._update_bg()
            if choice == "Aether":
                self.current_char = "kenji"
                self.current_dialogue = CHARACTERS["kenji"]["dialogue"]["farewell"]
            elif choice == "Lumina":
                self.current_char = "lumina"
                self.current_dialogue = CHARACTERS["lumina"]["dialogue"]["greeting"]
            elif choice == "Umbra":
                self.current_char = "umbra"
                self.current_dialogue = CHARACTERS["umbra"]["dialogue"]["greeting"]
            else:
                self.current_char = None
                self.current_dialogue = [f"Welcome to {choice}.", REALMS[choice]["desc"]]
            self.dialogue_index = 0
            self._show_line()
        elif "Compassion" in choice:
            self.current_dialogue = ["Compassion is the gravity of this world.",
                                    "When you act with care, realms respond.",
                                    "The Web bends toward kindness."]
            self.dialogue_index = 0
            self._show_line()
        elif "Silent" in choice:
            self.current_dialogue = ["Silence is a form of attention.",
                                    "Sometimes the deepest understanding comes from listening."]
            self.dialogue_index = 0
            self._show_line()
    
    def _handle_button(self, name):
        if name == "new":
            self._start_new()
        elif name == "continue":
            self.scene = "game"
            self._show_title_btns(False)
            self._start_intro()
        elif name == "codex":
            self.scene = "codex"
            self.buttons["back"].visible = True
            self.textbox.set_text_instant(f"📜 CODEX\n\nSeals: {len(self.player.seals_discovered)}/81\n\n{chr(10).join([f'Seal {s}' for s in self.player.seals_discovered[:10]])}")
        elif name == "quit":
            self.running = False
        elif name == "back":
            self.scene = "title"
            self.buttons["back"].visible = False
            self._show_title_btns(True)
    
    def _handle_events(self):
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                self.running = False
                self._save()
            
            for name, btn in self.buttons.items():
                if btn.handle_event(event):
                    self._handle_button(name)
            
            for i, btn in enumerate(self.choice_btns):
                if btn.handle_event(event):
                    self._handle_choice(i)
            
            if event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE:
                    if not self.awaiting_choice and self.dialogue_index < len(self.current_dialogue) - 1:
