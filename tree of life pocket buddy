@dataclass
class Player:
    name: str = "Seeker"
    current_realm: str = "Aether"
    attention: float = 100.0
    max_attention: float = 100.0
    compassion: float = 50.0
    max_compassion: float = 100.0
    wisdom: float = 0.0
    level: int = 1
    seals_discovered: List[int] = field(default_factory=list)
    insights: List[str] = field(default_factory=list)
    visited_realms: List[str] = field(default_factory=list)
    
    def add_seal(self, num: int) -> bool:
        if num not in self.seals_discovered:
            self.seals_discovered.append(num)
            self.seals_discovered.sort()
            self.wisdom += 1.0
            if len(self.seals_discovered) % 9 == 0:
                self.level += 1
            return True
        return False

