import { ContinuityLedger, ContinuityRecord } from '../types/core-types';
import { Manifold } from './layer6-manifold';

export class Ledger {
  private ledger: ContinuityLedger = { appendOnly: true, index: [] };
  manifold: Manifold;

  constructor(manifold: Manifold) {
    this.manifold = manifold;
  }

  record(rec: Omit<ContinuityRecord, 'id' | 'timestamp'>): ContinuityRecord {
    const full: ContinuityRecord = {
      ...rec,
      id: require('uuid').v4(),
      timestamp: new Date().toISOString(),
    };
    this.ledger.index.push(full);
    return full;
  }

  recent(count: number = 64): ContinuityRecord[] {
    return this.ledger.index.slice(-count);
  }

  all(): ContinuityRecord[] {
    return this.ledger.index;
  }
}
