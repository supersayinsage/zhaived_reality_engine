export interface GovernanceEffect {
  type: 'Taiyi' | 'Yuanshi' | 'Lingbao' | 'Daode';
  apply: (traces: any[]) => any[];
}

export class TaoistGovernance {
  // Regulators that HazelDNA can invoke; they never impose themselves.
  private regulators: GovernanceEffect[] = [
    {
      type: 'Taiyi',
      apply: traces => traces, // keep coherence (future: divergence detection)
    },
    {
      type: 'Yuanshi',
      apply: traces => traces.map(t => ({ ...t, lineage: t.lineage ?? 'origin' })),
    },
    {
      type: 'Lingbao',
      apply: traces => {
        const totalEnergy = traces.reduce((sum, t) => sum + (t.energy ?? 0), 0);
        return traces.map(t => ({ ...t, energy: (t.energy ?? 0) / (totalEnergy || 1) }));
      },
    },
    {
      type: 'Daode',
      apply: traces => traces.filter(() => Math.random() > 0.2), // wu‑wei: non‑forcing, allow some to dissolve
    },
  ];

  apply(traces: any[]): any[] {
    return this.regulators.reduce((acc, reg) => reg.apply(acc), traces);
  }
}
